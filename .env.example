# Dhan API
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_API_KEY=
DHAN_API_SECRET=

# Bright Data Proxy
# BRD_PROXY_USER and BRD_PROXY_PASS are required when proxy.enabled=true in config.yaml.
BRD_PROXY_HOST=brd.superproxy.io
BRD_PROXY_PORT=33335
BRD_PROXY_USER=brd-customer-<customer_id>-zone-<zone_name>
BRD_PROXY_PASS=
# BRD_PIN_IP pins the exit IP to a specific static IP in the Bright Data zone.
# This value MUST match the IP you have whitelisted on Dhan's API console.
# If unset, no IP suffix is appended and Bright Data may rotate the exit IP,
# causing DH-905 errors because Dhan only accepts whitelisted IPs.
BRD_PIN_IP=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
