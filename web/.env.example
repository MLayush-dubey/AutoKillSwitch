# Database (SQLite for local dev; swap to postgresql:// for production)
DATABASE_URL="file:./dev.db"

# NextAuth v5 — generate with: npx auth secret
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional for local dev; email/password works without it)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
