# Database (SQLite for local dev; swap to postgresql:// for production)
DATABASE_URL="file:./dev.db"

# NextAuth v5 — generate with: npx auth secret
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional for local dev; email/password works without it)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend — contact form + transactional emails
# (optional in dev: messages log to console if unset)
RESEND_API_KEY=""
CONTACT_TO_EMAIL="founders@autokillswitch.in"
CONTACT_FROM_EMAIL="AutoKillSwitch <contact@autokillswitch.in>"

# Public base URL used inside email templates for absolute links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Razorpay — test or live credentials. When unset, billing runs in mock
# mode: the UI flows work end-to-end but no real charges happen.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
